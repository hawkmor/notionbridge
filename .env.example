# Notion API Configuration
NOTION_API_KEY=secret_your_notion_api_key_here
NOTION_DATABASE_ID=your_database_id_here

# Xiaohongshu Scraper Configuration
# Set to 'true' to use real scraper, 'false' to use mock data
USE_REAL_SCRAPER=false
# Set to 'false' for debugging (shows browser window)
HEADLESS_MODE=true
# Your Xiaohongshu board/album URL (e.g., https://www.xiaohongshu.com/board/xxxxx)
XHS_BOARD_URL=https://www.xiaohongshu.com/board/your_board_id_here

# Logging Level (user|debug|verbose)
LOG_LEVEL=user

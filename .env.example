# Notion API Configuration
NOTION_API_KEY=secret_your_notion_api_key_here
NOTION_DATABASE_ID=your_database_id_here
# Optional: set to none to disable page icons
NOTION_PAGE_ICON_URL=https://s3-us-west-2.amazonaws.com/public.notion-static.com/16787851-26e1-4354-ac60-8a3574f1182e/rednote.png

# Xiaohongshu Scraper Configuration
# Set to 'true' to use real scraper, 'false' to use mock data
USE_REAL_SCRAPER=false
# Set to 'false' for debugging (shows browser window)
HEADLESS_MODE=true
# Your Xiaohongshu board/album URL (e.g., https://www.xiaohongshu.com/board/xxxxx)
XHS_BOARD_URL=https://www.xiaohongshu.com/board/your_board_id_here

# CloakBrowser Anti-Detection Settings
# Enable human-like mouse/keyboard/scroll behavior (recommended)
CLOAKBROWSER_HUMANIZE=true
# Browser profile directory for persistent sessions
CLOAKBROWSER_PROFILE_DIR=./browser_profile

# Logging Level (user|debug|verbose)
LOG_LEVEL=user

# Media uploads
# Set false for fast backfills; skipped videos are kept as bookmark links.
SYNC_VIDEO_UPLOADS=true
MAX_VIDEO_UPLOAD_MB=100
